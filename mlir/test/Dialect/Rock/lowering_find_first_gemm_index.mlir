// RUN: rocmlir-opt --rock-find-first-gemm-index %s -verify-diagnostics -o -| FileCheck %s


memref.global "private" constant @__constant_1x1x1x2048xf32 : memref<1x1x1x2048xf32> = dense<""> {alignment = 64 : i64}

// CHECK-LABEL: find_first_gemm_index_change
func.func @find_first_gemm_index_change(%arg0: memref<12288xf16>, %arg1: memref<8388608xf16>, %arg2: memref<8388608xf16>, %arg3: memref<1xf32>, %arg4: memref<4096xf16>) attributes {kernel} {
  %cst = arith.constant 0xFC00 : f16
  %0 = memref.get_global @__constant_1x1x1x2048xf32 : memref<1x1x1x2048xf32>
  %1 = rock.transform %arg1 by <affine_map<(d0, d1, d2, d3) -> ((d1 * 2048 + d2) * 128 + d3)> by [<Unmerge{32, 2048, 128} ["exp1", "exp2", "exp3"] at [1, 2, 3] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 32, 2048, 128] -> [8388608]> : memref<8388608xf16> to memref<1x32x2048x128xf16>
  %2 = rock.transform %arg0 by <affine_map<(d0, d1, d2, d3) -> (d1 * 128 + d3)> by [<Unmerge{96, 128} ["exp1", "exp3"] at [1, 3] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>, <AddDim{1} ["unit2"] at [2] -> [] at []>] bounds = [1, 96, 1, 128] -> [12288]> : memref<12288xf16> to memref<1x96x1x128xf16>
  %3 = rock.transform %2 by <affine_map<(d0, d1, d2, d3) -> (d0, d1, d2, d3)> by [<Slice{0, 1, 0, 32, 0, 1, 0, 128} ["dim0_sliced", "dim1_sliced", "dim2_sliced", "dim3_sliced"] at [0, 1, 2, 3] -> ["dim0", "dim1", "dim2", "dim3"] at [0, 1, 2, 3]>] bounds = [1, 32, 1, 128] -> [1, 96, 1, 128]> : memref<1x96x1x128xf16> to memref<1x32x1x128xf16>
  %4 = rock.transform %1 by <affine_map<(d0, d1, d2, d3) -> (d0, d1, d3, d2)> by [<PassThrough ["dim0", "dim1", "dim3", "dim2"] at [0, 1, 2, 3] -> ["dim0", "dim1", "dim3", "dim2"] at [0, 1, 3, 2]>] bounds = [1, 32, 128, 2048] -> [1, 32, 2048, 128]> : memref<1x32x2048x128xf16> to memref<1x32x128x2048xf16>
  %5 = rock.transform %3 by <affine_map<(d0, d1, d2) -> (0, d0, d1, d2)> by [<Merge{1, 32} ["dim0"] at [0] -> ["col0", "col1"] at [0, 1]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [2]>, <PassThrough ["dim2"] at [2] -> ["dim2"] at [3]>] bounds = [32, 1, 128] -> [1, 32, 1, 128]> : memref<1x32x1x128xf16> to memref<32x1x128xf16>
  %6 = rock.transform %4 by <affine_map<(d0, d1, d2) -> (0, d0, d1, d2)> by [<Merge{1, 32} ["dim0"] at [0] -> ["col0", "col1"] at [0, 1]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [2]>, <PassThrough ["dim2"] at [2] -> ["dim2"] at [3]>] bounds = [32, 128, 2048] -> [1, 32, 128, 2048]> : memref<1x32x128x2048xf16> to memref<32x128x2048xf16>
  %7 = rock.transform %arg2 by <affine_map<(d0, d1, d2) -> ((d0 * 2048 + d1) * 128 + d2)> by [<Unmerge{32, 2048, 128} ["exp0", "exp1", "exp2"] at [0, 1, 2] -> ["dim0"] at [0]>] bounds = [32, 2048, 128] -> [8388608]> : memref<8388608xf16> to memref<32x2048x128xf16>
  %alloc = memref.alloc() {alignment = 64 : i64} : memref<32x1x128xf16>
  rock.attention{
    qk = %5 * %6 : memref<32x1x128xf16>, memref<32x128x2048xf16>
    qk = elementwise otherIns(%arg3 : memref<1xf32>) {
  ^bb0(%arg5: memref<1xf32>, %arg6: memref<32x1x2048xf16>, %arg7: memref<1x32x1x2048xf16>):
    %11 = rock.transform %0 by <affine_map<(d0, d1, d2, d3) -> (d0, 0, d2, d3)> by [<PassThrough ["dim0"] at [0] -> ["dim0"] at [0]>, <Broadcast{1} ["dim1"] at [1] -> ["dim1"] at [1]>, <PassThrough ["dim2"] at [2] -> ["dim2"] at [2]>, <PassThrough ["dim3"] at [3] -> ["dim3"] at [3]>] bounds = [1, 32, 1, 2048] -> [1, 1, 1, 2048]> : memref<1x1x1x2048xf32> to memref<1x32x1x2048xf32>
    %12 = rock.transform %arg5 by <affine_map<(d0, d1) -> (d1)> by [<Unmerge{1} ["exp1"] at [1] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 1] -> [1]> : memref<1xf32> to memref<1x1xf32>
    %13 = rock.transform %12 by <affine_map<(d0, d1) -> (d0, 0)> by [<PassThrough ["dim0"] at [0] -> ["dim0"] at [0]>, <Broadcast{1} ["dim1"] at [1] -> ["dim1"] at [1]>] bounds = [1, 32] -> [1, 1]> : memref<1x1xf32> to memref<1x32xf32>
    %14 = rock.transform %13 by <affine_map<(d0, d1, d2, d3) -> (d0, d1)> by [<PassThrough ["dim0"] at [0] -> ["dim0"] at [0]>, <Unmerge{32} ["exp1"] at [1] -> ["dim1"] at [1]>, <AddDim{1} ["unit2"] at [2] -> [] at []>, <AddDim{1} ["unit3"] at [3] -> [] at []>] bounds = [1, 32, 1, 1] -> [1, 32]> : memref<1x32xf32> to memref<1x32x1x1xf32>
    %15 = rock.transform %14 by <affine_map<(d0, d1, d2, d3) -> (d0, d1, d2, 0)> by [<PassThrough ["dim0"] at [0] -> ["dim0"] at [0]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [1]>, <PassThrough ["dim2"] at [2] -> ["dim2"] at [2]>, <Broadcast{1} ["dim3"] at [3] -> ["dim3"] at [3]>] bounds = [1, 32, 1, 2048] -> [1, 32, 1, 1]> : memref<1x32x1x1xf32> to memref<1x32x1x2048xf32>
    %16 = rock.transform %arg6 by <affine_map<(d0, d1, d2, d3) -> (d1, d2, d3)> by [<Unmerge{32} ["exp1"] at [1] -> ["dim0"] at [0]>, <PassThrough ["dim1"] at [2] -> ["dim1"] at [1]>, <PassThrough ["dim2"] at [3] -> ["dim2"] at [2]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 32, 1, 2048] -> [32, 1, 2048]> : memref<32x1x2048xf16> to memref<1x32x1x2048xf16>
    %17 = rock.transform %11 by <affine_map<(d0, d1) -> (0, d0, 0, d1)> by [<Merge{1, 32, 1} ["dim0"] at [0] -> ["col0", "col1", "col2"] at [0, 1, 2]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [3]>] bounds = [32, 2048] -> [1, 32, 1, 2048]> : memref<1x32x1x2048xf32> to memref<32x2048xf32>
    %18 = rock.transform %15 by <affine_map<(d0, d1) -> (0, d0, 0, d1)> by [<Merge{1, 32, 1} ["dim0"] at [0] -> ["col0", "col1", "col2"] at [0, 1, 2]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [3]>] bounds = [32, 2048] -> [1, 32, 1, 2048]> : memref<1x32x1x2048xf32> to memref<32x2048xf32>
    %19 = rock.transform %16 by <affine_map<(d0, d1) -> (0, d0, 0, d1)> by [<Merge{1, 32, 1} ["dim0"] at [0] -> ["col0", "col1", "col2"] at [0, 1, 2]>, <PassThrough ["dim1"] at [1] -> ["dim1"] at [3]>] bounds = [32, 2048] -> [1, 32, 1, 2048]> : memref<1x32x1x2048xf16> to memref<32x2048xf16>
    %alloc_0 = memref.alloc() {alignment = 64 : i64} : memref<32x2048xf16>
    linalg.generic {indexing_maps = [affine_map<(d0, d1) -> (d0, d1)>, affine_map<(d0, d1) -> (d0, d1)>, affine_map<(d0, d1) -> (d0, d1)>, affine_map<(d0, d1) -> (d0, d1)>], iterator_types = ["parallel", "parallel"]} ins(%17, %18, %19 : memref<32x2048xf32>, memref<32x2048xf32>, memref<32x2048xf16>) outs(%alloc_0 : memref<32x2048xf16>) {
    ^bb0(%in: f32, %in_1: f32, %in_2: f16, %out: f16):
      %21 = arith.cmpf ogt, %in, %in_1 : f32
      %22 = arith.select %21, %cst, %in_2 : f16
      linalg.yield %22 : f16
    }
    %20 = rock.transform %alloc_0 by <affine_map<(d0, d1, d2, d3) -> (d1, d3)> by [<Unmerge{32} ["exp1"] at [1] -> ["dim0"] at [0]>, <PassThrough ["dim1"] at [3] -> ["dim1"] at [1]>, <AddDim{1} ["unit0"] at [0] -> [] at []>, <AddDim{1} ["unit2"] at [2] -> [] at []>] bounds = [1, 32, 1, 2048] -> [32, 2048]> : memref<32x2048xf16> to memref<1x32x1x2048xf16>
    memref.copy %20, %arg7 : memref<1x32x1x2048xf16> to memref<1x32x1x2048xf16>
    rock.yield
  }
    %alloc = softmax(qk) * %7 : memref<32x2048x128xf16> -> memref<32x1x128xf16>
  } {arch = "gfx942:sramecc+:xnack-", features = #rock<GemmFeatures mfma|dot|atomic_add|atomic_add_f16>, firstGemmIdx = 1 : i32, softmaxType = f16}
  // CHECK: firstGemmIdx = 2 : i32
  %8 = rock.transform %alloc by <affine_map<(d0, d1, d2, d3) -> (d1, d2, d3)> by [<Unmerge{32} ["exp1"] at [1] -> ["dim0"] at [0]>, <PassThrough ["dim1"] at [2] -> ["dim1"] at [1]>, <PassThrough ["dim2"] at [3] -> ["dim2"] at [2]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 32, 1, 128] -> [32, 1, 128]> : memref<32x1x128xf16> to memref<1x32x1x128xf16>
  %9 = rock.transform %8 by <affine_map<(d0, d1, d2, d3) -> (d0, d2, d1, d3)> by [<PassThrough ["dim0", "dim2", "dim1", "dim3"] at [0, 1, 2, 3] -> ["dim0", "dim2", "dim1", "dim3"] at [0, 2, 1, 3]>] bounds = [1, 1, 32, 128] -> [1, 32, 1, 128]> : memref<1x32x1x128xf16> to memref<1x1x32x128xf16>
  %10 = rock.transform %9 by <affine_map<(d0) -> (0, 0, d0 floordiv 128, d0 mod 128)> by [<Merge{1, 1, 32, 128} ["dim0"] at [0] -> ["col0", "col1", "col2", "col3"] at [0, 1, 2, 3]>] bounds = [4096] -> [1, 1, 32, 128]> : memref<1x1x32x128xf16> to memref<4096xf16>
  memref.copy %10, %arg4 : memref<4096xf16> to memref<4096xf16>
  return
}

// CHECK-LABEL: find_no_change
func.func @find_no_change(%arg0: memref<4096xf32>, %arg1: memref<4096xf32>, %arg2: memref<4096xf32>, %arg3: memref<4096xf32>) attributes {kernel} {
  %0 = rock.transform %arg2 by <affine_map<(d0, d1, d2) -> (d1 * 64 + d2)> by [<Unmerge{64, 64} ["exp1", "exp2"] at [1, 2] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 64, 64] -> [4096]> : memref<4096xf32> to memref<1x64x64xf32>
  %1 = rock.transform %arg1 by <affine_map<(d0, d1, d2) -> (d1 * 64 + d2)> by [<Unmerge{64, 64} ["exp1", "exp2"] at [1, 2] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 64, 64] -> [4096]> : memref<4096xf32> to memref<1x64x64xf32>
  %2 = rock.transform %arg0 by <affine_map<(d0, d1, d2) -> (d1 * 64 + d2)> by [<Unmerge{64, 64} ["exp1", "exp2"] at [1, 2] -> ["dim0"] at [0]>, <AddDim{1} ["unit0"] at [0] -> [] at []>] bounds = [1, 64, 64] -> [4096]> : memref<4096xf32> to memref<1x64x64xf32>
  %alloc = memref.alloc() {alignment = 64 : i64} : memref<1x64x64xf32>
  rock.attention{
    qk = %2 * %1 : memref<1x64x64xf32>, memref<1x64x64xf32>
    qk = elementwise {
  ^bb0(%arg4: memref<1x64x64xf32>, %arg5: memref<1x64x64xf32>):
    memref.copy %arg4, %arg5 : memref<1x64x64xf32> to memref<1x64x64xf32>
    rock.yield
  }
    %alloc = softmax(qk) * %0 : memref<1x64x64xf32> -> memref<1x64x64xf32>
  } {arch = "gfx942:sramecc+:xnack-", features = #rock<GemmFeatures mfma|dot|atomic_add|atomic_add_f16>, firstGemmIdx = 0 : i32, softmaxType = f32}
  // CHECK: firstGemmIdx = 0 : i32
  %3 = rock.transform %alloc by <affine_map<(d0) -> (0, d0 floordiv 64, d0 mod 64)> by [<Merge{1, 64, 64} ["dim0"] at [0] -> ["col0", "col1", "col2"] at [0, 1, 2]>] bounds = [4096] -> [1, 64, 64]> : memref<1x64x64xf32> to memref<4096xf32>
  memref.copy %3, %arg3 : memref<4096xf32> to memref<4096xf32>
  return
}
