                                                --configs_file=${convToUse} \
                                                --tuning_db=${WORKSPACE}/build/mlir_tuning_${CHIP}.tsv \
                                                --quick_tuning_db=${WORKSPACE}/build/mlir_quick_tuning_${CHIP}.tsv"""
                                            // Run MLIR vs rocBLAS perf benchmarks
